# Database (Supabase)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
DATABASE_URL_POOLED=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

# JWT
JWT_SECRET=change-this-to-a-long-random-string-minimum-64-chars
JWT_REFRESH_SECRET=change-this-to-a-different-long-random-string

# Session (Admin ERP)
SESSION_SECRET=change-this-to-yet-another-long-random-string

# API
API_PORT=3001
API_HOST=0.0.0.0

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=hmu-files
R2_PUBLIC_URL=

# Redis (BullMQ only)
REDIS_URL=redis://localhost:6379

# Firebase (push notifications)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=