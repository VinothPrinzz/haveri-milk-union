{
  "name": "haveri-milk-union",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "pnpm --filter api dev",
    "dev:web": "pnpm --filter web dev",
    "dev:worker": "pnpm --filter worker dev",
    "db:generate": "pnpm --filter @hmu/db generate",
    "db:migrate": "pnpm --filter @hmu/db migrate",
    "db:studio": "pnpm --filter @hmu/db studio"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "dependencies": {
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.1"
  },
  "pnpm": {
    "overrides": {
      "drizzle-orm": "0.45.2"
    }
  },
}
